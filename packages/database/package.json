{
    "name": "@boni/database",
    "version": "1.0.0",
    "description": "Shared database package with Prisma client and types",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "scripts": {
        "build": "tsc",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:reset": "prisma migrate reset --force",
        "db:seed": "prisma db seed",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@prisma/client": "^7.2.0",
        "@prisma/adapter-pg": "^7.2.0"
    },
    "devDependencies": {
        "prisma": "^7.2.0",
        "typescript": "^5.7.3"
    },
    "files": [
        "dist",
        "prisma"
    ]
}